# ── Banco de dados (obrigatório) ──────────────────────────────────────────
# Formato: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://user:password@localhost:5432/crm_infoprodutos

# ── Hotmart API ───────────────────────────────────────────────────────────
# Obtenha em: painel Hotmart → Ferramentas → Credenciais de API
HOTMART_CLIENT_ID=
HOTMART_CLIENT_SECRET=

# URLs base da Hotmart (opcionais — padrões já configurados)
HOTMART_BASE_URL=https://developers.hotmart.com
HOTMART_AUTH_URL=https://api-sec-vlc.hotmart.com

# ── Servidor ──────────────────────────────────────────────────────────────
PORT=3001

# ── CORS — Frontend (preencher após deploy na Vercel) ─────────────────────
# Exemplo: FRONTEND_URL=https://crm-infoprodutos.vercel.app
FRONTEND_URL=
